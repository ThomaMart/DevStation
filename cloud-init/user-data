#cloud-config

hostname: devstation-vm

users:
  - name: thomas
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: sudo
    ssh_authorized_keys:
      - REPLACE_WITH_PUBLIC_KEY

package_update: true
package_upgrade: true

packages:
  - qemu-guest-agent

runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent
